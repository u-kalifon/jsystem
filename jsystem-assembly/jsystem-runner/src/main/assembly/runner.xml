<assembly
	xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2 http://maven.apache.org/xsd/assembly-1.1.2.xsd">
	<formats>
		<format>tar.gz</format>
		<format>zip</format>
		<format>dir</format>
	</formats>
	<id>runner</id>
	<dependencySets>
		<dependencySet>
			<outputDirectory>thirdparty</outputDirectory>
			<unpack>true</unpack>
			<directoryMode>774</directoryMode>
			<fileMode>774</fileMode>
			<includes>
				<include>ant:ant-full:*</include>
			</includes>
			<unpackOptions>
				<excludes>
					<exclude>ant/docs/**</exclude>
				</excludes>
			</unpackOptions>
		</dependencySet>
		<dependencySet>
			<outputDirectory>thirdparty/ant/lib</outputDirectory>
			<outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
			<includes>
				<include>*:ant-contrib:*</include>
			</includes>
		</dependencySet>
		<dependencySet>
			<outputDirectory>thirdparty/commonLib</outputDirectory>
			<outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
			<includes>
				<include>*:ant:*</include>
				<include>*:ant-launcher:*</include>
				<include>*:asm:*</include>
				<include>*:asm-commons:*</include>
				<include>*:asm-tree:*</include>
				<include>*:commons-codec:*</include>
				<include>*:commons-httpclient:*</include>
				<include>*:commons-jxpath:*</include>
				<include>*:hamcrest-core:*</include>
				<include>*:jcommon:*</include>
				<include>*:jfreechart:*</include>
				<include>*:junit:*</include>
				<include>*:jython:*</include>
				<!-- include>*:log4j:*</include -->
				<include>*:slf4j-api:*</include>
				<include>*:logback-classic:*</include>
				<include>*:logback-core:*</include>
				<include>*:jul-to-slf4j:*</include>
				<include>*:mail:*</include>
				<include>*:javaparser-core:*</include>
				<include>*:serializer:*</include>
				<include>*:xalan:*</include>
				<include>*:xml-apis:*</include>
				<include>*:activation:*</include>
				<include>*:commons-logging:*</include>
				<include>*:commons-logging-api:*</include>
				<include>*:commons-io:*</include>
				<include>*:commons-compress:*</include>
				<include>*:commons-text:*</include>
				<include>*:commons-lang3:*</include>
				<include>*:looks:*</include>
				<include>*:commons-net:*</include>
				<include>*:ftpserver-core:*</include>
				<include>*:swingx:*</include>
				<include>*:junit:*</include>
				<include>*:swing-worker:*</include>
				<include>*:filters:*</include>
				<include>*:jackson-databind:*</include>
				<include>*:jackson-annotations:*</include>
				<include>*:jackson-core:*</include>
				<include>*:jackson-dataformat-xml:*</include>
				<include>*:stax2-api:*</include>
			</includes>
		</dependencySet>
		<dependencySet>
			<outputDirectory>lib</outputDirectory>
			<outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
			<includes>
				<include>org.jsystemtest:*:jar</include>
			</includes>
			<excludes>
				<exclude>*:jsystem-runner:*</exclude>
			</excludes>
		</dependencySet>
	</dependencySets>
	<fileSets>
		<fileSet>
			<outputDirectory>dev</outputDirectory>
			<directory>src/main/dev</directory>
		</fileSet>
		<fileSet>
			<outputDirectory></outputDirectory>
			<directory>src/main/etc</directory>
			<excludes>
				<exclude>run</exclude>
				<exclude>runBase</exclude>
				<exclude>runAgent</exclude>
			</excludes>
		</fileSet>
		<fileSet>
			<outputDirectory></outputDirectory>
			<directory>src/main/etc</directory>
			<fileMode>775</fileMode>
			<includes>
				<include>run</include>
				<include>runBase</include>
				<include>runAgent</include>
			</includes>
		</fileSet>

	</fileSets>

</assembly>
